# OpenRouter API Key (required for open-source cloud models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Ollama base URL (for local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Local fallback model (Ollama model name)
LOCAL_FALLBACK_MODEL=qwen2.5-coder:7b

# Memory persistence directory
MEMORY_DIR=~/.coding_agent/memory
STATE_DIR=~/.coding_agent/state

# Max concurrent sub-agents
MAX_SUBAGENTS=30

# Deployment topology
DEEPAGENTS_DEPLOYMENT_TOPOLOGY=split

# Optional LangGraph deployment settings for single topology
LANGGRAPH_DEPLOYMENT_URL=
LANGGRAPH_ASSISTANT_ID=supervisor

# Local async subagent runtime
ASYNC_SUBAGENT_HOST=127.0.0.1
ASYNC_SUBAGENT_BASE_PORT=30240

# Docker / compose
CODING_AGENT_PORT=8501
CODING_AGENT_IMAGE=leesk212/coding-ai-agent-v5:latest
