# OpenRouter API Key (required for open-source cloud models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Ollama base URL (for local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Local fallback model (Ollama model name)
LOCAL_FALLBACK_MODEL=qwen2.5-coder:7b

# Memory persistence directory
MEMORY_DIR=~/.coding_agent/memory

# Max concurrent sub-agents
MAX_SUBAGENTS=3
